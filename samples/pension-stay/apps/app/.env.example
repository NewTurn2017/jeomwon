# Convex
NEXT_PUBLIC_CONVEX_URL=

# Dev-only auth shortcut shown by the server-rendered login page.
# Set to 1 only for explicit dev app deployments. Never set in production.
AUTH_DEV_ANONYMOUS=

# Agent runtime for the authenticated /api/chat route (features.customerAccounts).
# mock = deterministic engine (no key needed); openai = OpenAI Agents SDK.
AGENT_RUNTIME=mock

# Only required when AGENT_RUNTIME=openai. Read by the app route handler.
OPENAI_API_KEY=
