# Site
SITE_URL=http://localhost:3001

# Dev-only Convex Auth Anonymous provider.
# Set with `npx convex env set AUTH_DEV_ANONYMOUS 1` only on dev deployments.
# Never set in production.
AUTH_DEV_ANONYMOUS=

# Optional Polar billing. Required only when domain.config features.polar=true.
# Set these as Convex env vars via setup or convex env set before using Polar.
POLAR_ORGANIZATION_TOKEN=
POLAR_WEBHOOK_SECRET=
