{
  "name": "jeomwon-app",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "turbo build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "dev": "turbo dev --parallel",
    "dev:web": "turbo dev --filter=@jeomwon/web",
    "dev:jobs": "turbo jobs --filter=@jeomwon/jobs",
    "dev:app": "turbo dev --filter=@jeomwon/app",
    "start:web": "turbo start --filter=@jeomwon/web",
    "start:app": "turbo start --filter=@jeomwon/app",
    "test": "bun test",
    "qa": "bun scripts/qa-local.ts",
    "qa:run": "tsx scripts/qa.ts",
    "setup": "bun scripts/setup/index.ts",
    "format": "biome format --write .",
    "lint": "turbo lint && biome lint scripts",
    "lint:repo": "bunx sherif@latest",
    "lint:repo:fix": "bunx sherif@latest --fix",
    "typecheck": "turbo typecheck && tsc --noEmit -p packages/backend/convex/tsconfig.json && tsc --noEmit -p packages/backend/tests/tsconfig.json && tsc --noEmit -p scripts/setup/tsconfig.json && tsc --noEmit -p scripts/tsconfig.json"
  },
  "devDependencies": {
    "@jeomwon/typescript": "workspace:*",
    "@biomejs/biome": "^2.2.4",
    "@playwright/test": "^1.59.1",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@types/bun": "^1.3.5",
    "@types/node": "^24.0.0",
    "chalk": "^5.6.2",
    "dotenv": "^17.2.3",
    "ora": "^8.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "turbo": "^2.10.2",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@auth/core": "^0.37.0",
    "jose": "^5.10.0"
  },
  "version": "0.0.1"
}
