# Convex
NEXT_PUBLIC_CONVEX_URL=

# Product guest login shown by the server-rendered login page. Setup keeps this
# server-only flag synchronized with the Convex deployment flag. Default is off.
# Production requires an explicit setup opt-in and a non-empty admin allowlist.
AUTH_ANONYMOUS_LOGIN=

# Public presentation-only marker for the dedicated demo app deployment.
# This does not enable anonymous login or server-side reset behavior.
# Leave blank or unset to disable it; the only enabled value is exactly 1.
NEXT_PUBLIC_JEOMWON_DEMO=

# Agent runtime for the authenticated customer app's /api/chat route.
# mock = deterministic engine (no key needed); openai = OpenAI Agents SDK.
AGENT_RUNTIME=mock

# Only required when AGENT_RUNTIME=openai. Read by the app route handler.
OPENAI_API_KEY=
