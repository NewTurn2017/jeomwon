{
  "extends": "../../tooling/typescript/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@jeomwon/backend": ["../../packages/backend"],
      "@jeomwon/backend/*": ["../../packages/backend/*"],
      "@jeomwon/email/reservation": [
        "../../packages/email/src/reservation.tsx"
      ],
      "@jeomwon/ui/globals.css": ["../../packages/ui/src/globals.css"],
      "@jeomwon/ui/utils": ["../../packages/ui/src/utils/index.ts"],
      "@jeomwon/ui/*": ["../../packages/ui/src/components/*"]
    },
    "strict": true
  },
  "include": [
    "next-env.d.ts",
    "next.config.js",
    "next.config.mjs",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/env.mjs"
  ],
  "exclude": ["node_modules"]
}
